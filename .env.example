# Copy to .env.local once you've created your Sanity project.
# Get these values by running `npm run studio:init` (interactive) or from
# https://www.sanity.io/manage → your project → API.

# Used by both the Astro site (build-time fetch) and the Studio (dev/deploy).
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Optional — pin to a date string. Defaults to 2024-10-01.
# PUBLIC_SANITY_API_VERSION=2024-10-01

# Mirror of the public ones, named the way `sanity` CLI expects.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
