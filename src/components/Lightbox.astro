<div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="Media preview">
  <button class="lightbox__close" id="lightboxClose" aria-label="Close preview">✕</button>
  <div class="lightbox__inner">
    <div class="lightbox__media" id="lightboxMedia"></div>
    <div class="lightbox__caption mono">
      <span id="lightboxCaption"></span>
      <span class="mono-micro">Esc to close</span>
    </div>
  </div>
</div>
