---
import type { Card } from '../data/cards';

export interface Props { card: Card; pinned?: boolean; index?: number; }
const { card, pinned = false, index = 0 } = Astro.props;

// Resolve BASE-relative paths only when they start with "/"
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolve = (path: string) =>
  path.startsWith('/') ? `${base}${path}` : path;

// Wide cards span 2 grid columns: all videos, plus any image whose
// Sanity "meta" field is "Kudos" (case-insensitive). Quotes never widen.
const isWide =
  card.type === 'video' ||
  (card.type === 'image' && (card.meta || '').trim().toLowerCase() === 'kudos');

// The first N cards in DOM order get high-priority eager loading so the
// above-the-fold content paints quickly. Everything past that lazy-loads
// when it nears the viewport, keeping initial download light.
const EAGER_THRESHOLD = 8;
const isEager = index < EAGER_THRESHOLD;
const imgLoading = isEager ? 'eager' : 'lazy';
const imgPriority = isEager ? 'high' : 'low';
const videoPreload = isEager ? 'metadata' : 'none';
---
{card.type === 'quote' ? (
  <article
    class="card card--quote"
    data-type="quote"
    data-pinned={pinned ? 'true' : undefined}
  >
    <div class="quote">
      <div class="quote__mark" aria-hidden="true">“</div>
      <p class="quote__body">{card.body}</p>
      <div class="quote__attr">
        <div class="quote__avatar" aria-hidden="true">{card.avatar}</div>
        <div class="quote__attr-text">
          <span class="quote__attr-name">{card.name}</span>
          <span class="quote__attr-role">{card.role}</span>
        </div>
      </div>
    </div>
    <div class="card__caption">
      <span class="card__name">{card.client}</span>
      <span class="card__meta">{card.meta}</span>
    </div>
  </article>
) : (
  <article
    class:list={['card', { 'is-wide': isWide }]}
    data-type={card.type}
    data-pinned={pinned ? 'true' : undefined}
    data-src={resolve(card.full)}
    data-caption={card.caption}
  >
    <div class="card__media">
      <span class="card__type-tag">{card.type}</span>
      {card.type === 'video' ? (
        <video
          src={resolve(card.thumb)}
          muted loop playsinline
          preload={videoPreload}
          aria-label={card.alt}
          width={card.width}
          height={card.height}
          style={card.width && card.height
            ? `aspect-ratio: ${card.width} / ${card.height};`
            : 'aspect-ratio: 16 / 9;'}
        ></video>
      ) : (
        <img
          src={resolve(card.thumb)}
          alt={card.alt}
          loading={imgLoading}
          fetchpriority={imgPriority}
          decoding="async"
          width={card.width}
          height={card.height}
        />
      )}
      <div class="card__play" aria-hidden="true">
        <span>{card.type === 'video' ? '▶' : '↗'}</span>
      </div>
    </div>
    <div class="card__caption">
      <span class="card__name">{card.client}</span>
      <span class="card__meta">{card.meta}</span>
    </div>
  </article>
)}
