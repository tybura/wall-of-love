---
export interface Props {
  eyebrow?: string;
  title?: string;
  sub?: string;
  stats?: { value: string; label: string }[];
}

const {
  eyebrow = 'Speedrun 006, from our side of the build.',
  title = 'Words from the founders we built with.',
  sub = 'Two months inside speedrun: real quotes, live screens, work that shipped. Founders brought the vision, we brought the pixels, nobody slept much.',
  stats = [
    { value: '42', label: 'Projects shipped'    },
    { value: '28', label: 'Founders served'     },
    { value: '20', label: 'Designers on site'   },
    { value: '∞',  label: 'Fun had'             },
  ],
} = Astro.props;
---
<section class="hero">
  <div class="hero__eyebrow mono"><span>{eyebrow}</span></div>

  <h1 class="display hero__title">{title}</h1>

  <p class="hero__sub">{sub}</p>

  <div class="hero__stats">
    {stats.map(s => (
      <div class="hero__stat">
        <div class="hero__stat-value">{s.value}</div>
        <div class="hero__stat-label">{s.label}</div>
      </div>
    ))}
  </div>
</section>
