---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Wall from '../components/Wall.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';
---
<Layout>
  <Header />
  <main id="top">
    <Hero />
    <Wall />
  </main>
  <Footer />
  <Lightbox />
</Layout>

<script>
  // ============ Shuffle cards on every visit ===================
  // Build-time order comes from Sanity (manual `order` field). For the
  // visitor we randomize so the wall feels fresh on every refresh. Cards
  // start opacity:0 via CSS, so reordering happens before they're painted.
  const grid = document.getElementById('grid');
  if (grid) {
    const cardEls = Array.from(grid.children) as HTMLElement[];
    for (let i = cardEls.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [cardEls[i], cardEls[j]] = [cardEls[j], cardEls[i]];
    }
    const frag = document.createDocumentFragment();
    cardEls.forEach(c => frag.appendChild(c));
    grid.appendChild(frag);
  }

  // ============ Layout switcher (column count) =================
  const layoutBtns = document.querySelectorAll<HTMLButtonElement>('.layout-btn');
  layoutBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      layoutBtns.forEach(b =>
        b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'));
      if (grid && btn.dataset.layout) grid.dataset.cols = btn.dataset.layout;
    });
  });

  // ============ Masonry row-span layout ========================
  // CSS Grid + grid-auto-rows:0 + per-card grid-row-end:span N = true masonry
  // that also supports column spans (wide cards = .is-wide spans 2 columns).
  const layoutMasonry = () => {
    if (!grid) return;
    const rowGap = parseFloat(getComputedStyle(grid).rowGap) || 0;
    if (rowGap <= 0) return;
    const children = Array.from(grid.children) as HTMLElement[];
    // Reset all spans so we measure unconstrained heights
    children.forEach(el => { el.style.gridRowEnd = ''; });
    // Force reflow once, then read every height in a single pass
    void grid.offsetHeight;
    children.forEach(el => {
      const h = el.getBoundingClientRect().height;
      if (h <= 0) return;
      el.style.gridRowEnd = `span ${Math.ceil((h + rowGap) / rowGap)}`;
    });
  };

  // Schedule a layout pass — coalesces multiple triggers in the same frame
  let rafPending = false;
  const scheduleLayout = () => {
    if (rafPending) return;
    rafPending = true;
    requestAnimationFrame(() => {
      rafPending = false;
      layoutMasonry();
    });
  };

  // Initial pass (cards measured as text-only first, will re-run on image load)
  scheduleLayout();

  // Re-layout once each image/video finishes loading
  grid?.querySelectorAll<HTMLImageElement | HTMLVideoElement>('img, video').forEach(el => {
    if (el instanceof HTMLImageElement && el.complete && el.naturalHeight > 0) return;
    const handler = () => scheduleLayout();
    el.addEventListener('load', handler, { once: true });
    el.addEventListener('loadeddata', handler, { once: true });
    el.addEventListener('error', handler, { once: true });
  });

  // Re-layout on viewport resize (debounced via rAF)
  window.addEventListener('resize', scheduleLayout);

  // Re-layout when the layout switcher changes data-cols
  if (grid) {
    new MutationObserver(scheduleLayout)
      .observe(grid, { attributes: true, attributeFilter: ['data-cols'] });
  }

  // Cards that fade in via the IntersectionObserver below may shift height
  // when they transition — kick a layout pass on transitionend just in case.
  grid?.addEventListener('transitionend', e => {
    if ((e as TransitionEvent).propertyName === 'transform') scheduleLayout();
  });

  // ============ Filter buttons (currently hidden) ==============
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.card');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.filter;
      filterBtns.forEach(b => b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'));
      cards.forEach(card => {
        const match = type === 'all' || card.dataset.type === type;
        card.classList.toggle('is-hidden', !match);
      });
    });
  });

  // ============ Auto-play videos when in view ==================
  const videos = document.querySelectorAll<HTMLVideoElement>('.card[data-type="video"] video');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        const v = entry.target as HTMLVideoElement;
        if (entry.isIntersecting) v.play().catch(() => {});
        else v.pause();
      });
    }, { threshold: 0.4 });
    videos.forEach(v => io.observe(v));
  } else {
    videos.forEach(v => v.play().catch(() => {}));
  }

  // ============ Lightbox =======================================
  const lb = document.getElementById('lightbox')!;
  const lbMedia = document.getElementById('lightboxMedia')!;
  const lbCaption = document.getElementById('lightboxCaption')!;
  const lbClose = document.getElementById('lightboxClose')!;

  function openLightbox(card: HTMLElement) {
    const type = card.dataset.type;
    const src = card.dataset.src;
    const caption = card.dataset.caption || '';
    if (!src) return;

    if (type === 'video') {
      lbMedia.innerHTML = `<video src="${src}" controls autoplay muted loop playsinline></video>`;
    } else {
      lbMedia.innerHTML = `<img src="${src}" alt="${caption}" />`;
    }
    lbCaption.textContent = caption;
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    lbMedia.innerHTML = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLElement>('.card[data-src]').forEach(card => {
    card.querySelector<HTMLElement>('.card__media')
      ?.addEventListener('click', () => openLightbox(card));
  });

  lbClose.addEventListener('click', closeLightbox);
  lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && lb.classList.contains('is-open')) closeLightbox();
  });

  // ============ Subtle fade-in on scroll =======================
  // Cards start opacity:0 in CSS; we just flip the class when they enter view.
  if ('IntersectionObserver' in window) {
    const fadeIO = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          fadeIO.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    cards.forEach(c => fadeIO.observe(c));
  } else {
    cards.forEach(c => c.classList.add('is-visible'));
  }
</script>
